# ─────────────────────────────────────────────────────────────
# AI YouTube Summarizer — Environment Configuration Template
# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────

# ── Application ──────────────────────────────────────────────
APP_NAME="AI YouTube Summarizer"
APP_VERSION="1.0.0"
APP_ENV="development"          # development | staging | production
DEBUG=true

# ── FastAPI Backend ───────────────────────────────────────────
BACKEND_HOST="0.0.0.0"
BACKEND_PORT=8000
BACKEND_RELOAD=true            # Set false in production

# ── Streamlit Frontend ────────────────────────────────────────
FRONTEND_PORT=8501
BACKEND_URL="http://localhost:8000"

# ── AI Provider (Anthropic Claude) ───────────────────────────
ANTHROPIC_API_KEY="your-anthropic-api-key-here"
ANTHROPIC_MODEL="claude-opus-4-20250514"
ANTHROPIC_MAX_TOKENS=4096
ANTHROPIC_TEMPERATURE=0.3

# ── Transcript Settings ───────────────────────────────────────
MAX_TRANSCRIPT_LENGTH=50000    # Characters; trim long videos
TRANSCRIPT_LANGUAGES="en,en-US,en-GB"

# ── Summary Settings ─────────────────────────────────────────
SUMMARY_CACHE_TTL=3600         # Seconds to cache a summary (1 hour)

# ── CORS (comma-separated origins) ───────────────────────────
ALLOWED_ORIGINS="http://localhost:8501,http://127.0.0.1:8501"

# ── Logging ───────────────────────────────────────────────────
LOG_LEVEL="INFO"               # DEBUG | INFO | WARNING | ERROR
LOG_FILE="logs/app.log"
